<tool id="kraken_segment" name="Kraken Segment" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="26.1">
    <description>segment text regions and lines in document images</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements" />
    <expand macro="creators" />
    <command detect_errors="exit_code"><![CDATA[
        ln -s '$image' 'input.${image.ext}' &&
        kraken
            @VERBOSE_FLAGS@
            $output_format
            --raise-on-error
            --input 'input.${image.ext}' 'kraken_output'
            segment
                #if $segmenter.type == 'baseline'
                    --baseline
                    #if str($segmenter.model_name)
                        --model '$segmenter.model_name'
                    #end if
                #else
                    --boxes
                    #if str($segmenter.scale)
                        --scale '$segmenter.scale'
                    #end if
                    --maxcolseps '$segmenter.maxcolseps'
                    $segmenter.colseps
                    $segmenter.hlines
                    --pad '$segmenter.pad'
                #end if
                --text-direction '$text_direction'
                --input-pad '$input_pad'
        &&
        mv kraken_output '$output'
    ]]></command>
    <inputs>
        <param name="image" type="data" format="jpg,png,tif" label="Single image"/>
        <param name="output_format" type="select" label="Output format">
            <option value="-a" selected="true">ALTO XML</option>
            <option value="-x">PageXML</option>
            <option value="-h">hOCR</option>
            <option value="-y">abbyyXML</option>
            <option value="-n">JSON (kraken native format)</option>
        </param>
        <conditional name="segmenter">
            <param name="type" type="select" label="Segmenter type">
                <option value="baseline" selected="true">Neural baseline segmenter</option>
                <option value="boxes">Legacy box segmenter (requires binarised input image)</option>
            </param>

            <when value="baseline">
                <param 
                    name="model_name" 
                    type="text" optional="true" 
                    value="" label="Segmentation model name or path" 
                    help="Leave empty to use Kraken's internal stock baseline segmentation model. Otherwise provide the name or path of a segmentation model available to Kraken.">
                    <sanitizer>
                        <valid initial="string.ascii_letters,string.digits">
                            <add value="."/>
                            <add value="-"/>
                            <add value="_"/>
                            <add value="/"/>
                            <add value=":"/>
                        </valid>
                    </sanitizer>
                </param>
            </when>

            <when value="boxes">
                <param argument="--scale" type="float" optional="true" label="Scale"/>
                <param argument="--maxcolseps" type="integer" value="2" min="0" label="Maximum column separators"/>
                <param name="colseps" type="select" label="Column separator color">
                    <option value="--white_colseps" selected="true">White</option>
                    <option value="--black-colseps">Black</option>
                </param>
                <param name="hlines" type="select" label="Remove/keep horizontal lines">
                    <option value="--remove-hlines" selected="true">Remove horizontal lines</option>
                    <option value="--hlines">Keep horizontal lines</option>
                </param>
                <param argument="--pad" type="integer" value="0" min="0" label="Padding around segmented regions"/>
            </when>
        </conditional>
        <expand macro="verbose_param" />
        <param argument="--text-direction" type="select" label="Segmentation text direction">
            <option value="horizontal-lr" selected="true">Horizontal, left-to-right</option>
            <option value="horizontal-rl">Horizontal, right-to-left</option>
            <option value="vertical-lr">Vertical, left-to-right columns</option>
            <option value="vertical-rl">Vertical, right-to-left columns</option>
        </param>

        <param argument="--input-pad" type="integer" value="0" min="0" label="Padding to add around input image"/>
    </inputs>
    <outputs>
        <data name="output" format="json" label="${tool.name} on ${on_string}">
            <actions>
                <conditional name="output_format">
                    <when value="-a">
                        <action type="format" default="xml"/>
                    </when>
                    <when value="-x">
                        <action type="format" default="xml"/>
                    </when>
                    <when value="-h">
                        <action type="format" default="html"/>
                    </when>
                    <when value="-y">
                        <action type="format" default="xml"/>
                    </when>
                    <when value="-n">
                        <action type="format" default="json"/>
                    </when>
                </conditional>
            </actions>
        </data>
    </outputs>
    <tests>
        <test>
            <param name="image" value="kraken_input.png" ftype="png"/>
            <conditional name="segmenter">
                <param name="type" value="baseline"/>
                <param name="model_name" value=""/>
            </conditional>
            <output name="output" ftype="json">
                <assert_contents>
                    <has_size min="1"/>
                    <has_text text="&quot;imagename&quot;"/>
                    <has_text text="&quot;text_direction&quot;"/>
                    <has_text text="&quot;lines&quot;"/>
                    <has_text text="&quot;regions&quot;"/>
                </assert_contents>
            </output>
        </test>

        <test>
            <param name="image" value="kraken_input_binarised.png" ftype="png"/>
            <conditional name="segmenter">
                <param name="type" value="boxes"/>
                <param name="maxcolseps" value="2"/>
                <param name="colseps" value="--white_colseps"/>
                <param name="hlines" value="--remove-hlines"/>
                <param name="pad" value="0"/>
            </conditional>
            <output name="output" ftype="json">
                <assert_contents>
                    <has_size min="1"/>
                    <has_text text="&quot;imagename&quot;"/>
                    <has_text text="&quot;text_direction&quot;"/>
                    <has_text text="&quot;lines&quot;"/>
                    <has_text text="&quot;regions&quot;"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
        **What it does**

        This tool runs the kraken `segment` command on one document image and is able
        to produce segmentation output in various formats, such as ALTO XML, PageXML, 
        hOCR and abbyyXML. 

        For the segmentation it is recommended to use the neural baseline segmenter.
        with Kraken's internal stock segmentation model or you can select an alternative model.

        The legacy box segmenter is also available, but it expects a binarised
        image as input. If you do not have one yet, you can obtain it from the
        kraken binarise tool, which is also available in the htr-kraken tool suite.

        **Disclaimer**

        The output of the kraken segment command is not intended as the
        input for the Kraken OCR command.

        **License**

        Kraken is licensed under the Apache-2.0 license.
    ]]></help>
    <expand macro="citations" />
</tool>