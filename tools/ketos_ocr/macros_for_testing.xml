<macros>
    <xml name="compile_test_default_options">
        <param name="empty_lines" value="--skip-empty-lines"/>
        <param name="recordbatch_size" value="100"/>
    </xml>

    <xml name="compile_test_nondefault_options">
        <param name="force_type" value="bbox"/>
        <param name="empty_lines" value="--keep-empty-lines"/>
        <param name="recordbatch_size" value="1"/>
        <param name="legacy_polygons" value="true"/>
    </xml>

    <xml name="compile_test" tokens="format_type">
        <test expect_num_outputs="1">
            <conditional name="training_data">
                <param name="format_type" value="@FORMAT_TYPE@"/>
                <yield name="input"/>
            </conditional>

            <yield name="options"/>

            <output name="dataset" ftype="arrow">
                <assert_contents>
                    <has_size min="100"/>
                    <has_text text="ARROW1" n="2"/>
                </assert_contents>
            </output>

            <yield name="assertions"/>
        </test>
    </xml>

    <xml name="compile_repeat_test"
         tokens="format_type,image,annotation,annotation_ftype"
         token_image_ftype="png">
        <expand macro="compile_test" format_type="@FORMAT_TYPE@">
            <token name="input">
                <conditional name="input_source">
                    <param name="source" value="repeat"/>
                    <repeat name="ground_truth_pairs">
                        <param name="image"
                               value="@IMAGE@"
                               ftype="@IMAGE_FTYPE@"/>
                        <param name="annotation"
                               value="@ANNOTATION@"
                               ftype="@ANNOTATION_FTYPE@"/>
                    </repeat>
                </conditional>
            </token>
            <token name="options">
                <expand macro="compile_test_default_options"/>
            </token>
            <token name="assertions">
                <yield/>
            </token>
        </expand>
    </xml>

    <xml name="compile_collection_test"
         tokens="format_type,element_name,image,annotation,annotation_ftype"
         token_image_ftype="png">
        <expand macro="compile_test" format_type="@FORMAT_TYPE@">
            <token name="input">
                <conditional name="input_source">
                    <param name="source" value="collection"/>
                    <param name="ground_truth_collection">
                        <collection type="list:paired">
                            <element name="@ELEMENT_NAME@">
                                <collection type="paired">
                                    <element name="forward"
                                             value="@IMAGE@"
                                             ftype="@IMAGE_FTYPE@"/>
                                    <element name="reverse"
                                             value="@ANNOTATION@"
                                             ftype="@ANNOTATION_FTYPE@"/>
                                </collection>
                            </element>
                            <yield/>
                        </collection>
                    </param>
                </conditional>
            </token>
            <token name="options">
                <yield name="options"/>
            </token>
            <token name="assertions"/>
        </expand>
    </xml>

    <xml name="compile_repeat_failure_test"
        tokens="format_type,image,annotation,annotation_ftype,error"
        token_image_ftype="tiff"
        token_exit_code="1">
        <test expect_failure="true"
            expect_exit_code="@EXIT_CODE@"
            expect_num_outputs="0">
            <conditional name="training_data">
                <param name="format_type" value="@FORMAT_TYPE@"/>
                <conditional name="input_source">
                    <param name="source" value="repeat"/>
                    <repeat name="ground_truth_pairs">
                        <param name="image"
                            value="@IMAGE@"
                            ftype="@IMAGE_FTYPE@"/>
                        <param name="annotation"
                            value="@ANNOTATION@"
                            ftype="@ANNOTATION_FTYPE@"/>
                    </repeat>
                </conditional>
            </conditional>

            <expand macro="compile_test_default_options"/>

            <assert_stderr>
                <has_text text="@ERROR@"/>
            </assert_stderr>
        </test>
    </xml>
</macros>
