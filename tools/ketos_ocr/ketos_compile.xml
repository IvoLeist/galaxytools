<tool id="ketos_compile" name="Ketos Compile" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>precompile OCR training data into an Arrow dataset</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <command detect_errors="exit_code"><![CDATA[
        ketos
            @GLOBAL_ARGS@
            compile
            --output dataset.arrow
            --format-type '$format_type'
            #for $item in $files
                #if str($item).strip() and str($item) != 'None'
                    --files '$item'
                #end if
            #end for
            #if str($force_type).strip() and str($force_type) != 'None'
                --force-type '$force_type'
            #end if
            $empty_lines
            --recordbatch-size '$recordbatch_size'
            #if $legacy_polygons
                --legacy-polygons
            #end if
            #for $item in $ground_truth
                #if str($item).strip() and str($item) != 'None'
                    '$item'
                #end if
            #end for
    ]]></command>
    <expand macro="env_vars"/>
    <inputs>
        <expand macro="global_inputs"/>
        <param name="ground_truth" type="data" multiple="true" optional="true" format="txt,xml,alto,json,jpg,png,tiff" label="Ground-truth files"/>
        <param name="files" type="data" multiple="true" optional="true" format="txt" label="Manifest files"/>
        <param argument="--format-type" type="select" label="Training data format">
            <option value="xml" selected="true">XML</option>
            <option value="alto">ALTO</option>
            <option value="page">PageXML</option>
            <option value="path">Path/image pairs</option>
        </param>
        <param argument="--force-type" type="select" optional="true" label="Force dataset type">
            <option value="" selected="true">Auto-detect</option>
            <option value="bbox">Bounding boxes</option>
            <option value="baseline">Baselines</option>
        </param>
        <param name="empty_lines" type="select" label="Empty text lines">
            <option value="--skip-empty-lines" selected="true">Skip empty lines</option>
            <option value="--keep-empty-lines">Keep empty lines</option>
        </param>
        <param argument="--recordbatch-size" type="integer" min="1" value="100" label="Minimum records per Arrow RecordBatch"/>
        <param argument="--legacy-polygons" type="boolean" truevalue="true" falsevalue="false" checked="false" label="Use legacy polygon extractor"/>
    </inputs>
    <outputs>
        <data name="dataset" format="binary" from_work_dir="dataset.arrow" label="${tool.name} on ${on_string}: dataset.arrow"/>
    </outputs>
    <tests>
        <test expect_failure="true">
            <param name="ground_truth" value="ground_truth.txt" ftype="txt"/>
            <param name="files" value="manifest.txt" ftype="txt"/>
            <param name="format_type" value="path"/>
            <param name="force_type" value="bbox"/>
            <param name="empty_lines" value="--keep-empty-lines"/>
            <param name="recordbatch_size" value="2"/>
            <param name="legacy_polygons" value="true"/>
            <assert_command>
                <has_text text="ketos"/>
                <has_text text="compile"/>
                <has_text text="--format-type 'path'"/>
                <has_text text="--files"/>
                <has_text text="--force-type 'bbox'"/>
                <has_text text="--keep-empty-lines"/>
                <has_text text="--recordbatch-size '2'"/>
                <has_text text="--legacy-polygons"/>
            </assert_command>
        </test>
    </tests>
    <help format="markdown">
Compiles line or document ground-truth data into Kraken/Ketos' binary Arrow dataset format. Use the resulting dataset with Ketos training commands by selecting `binary` as the training data format.
    </help>
    <expand macro="citations"/>
</tool>
