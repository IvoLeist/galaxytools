<tool id="ketos_compile" name="Ketos Compile" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>precompile OCR training data into an Arrow dataset</description>

    <macros>
        <import>macros.xml</import>
    </macros>

    <expand macro="requirements"/>
    <expand macro="creators"/>

    <command detect_errors="exit_code"><![CDATA[
        #set $input_source = $training_data.input_source

        #if $input_source.source == 'repeat'
            #set $pairs = $input_source.ground_truth_pairs
        #else
            #set $pairs = $input_source.ground_truth_collection
        #end if

        #for $i, $pair in enumerate($pairs)
            #if $input_source.source == 'repeat'
                #set $image = $pair.image
                #if $training_data.format_type == 'path'
                    #set $annotation = $pair.transcription
                #else
                    #set $annotation = $pair.annotation
                #end if
            #else
                #set $image = $pair.forward
                #set $annotation = $pair.reverse
            #end if

            #if $training_data.format_type == 'path'
                ln -s '$image' 'ground_truth_${i}.${image.ext}' &&
                ln -s '$annotation' 'ground_truth_${i}.gt.txt' &&
            #else
                mkdir -p 'ground_truth_${i}' &&
                ln -s '$image' 'ground_truth_${i}/input.png' &&
                ln -s '$annotation' 'ground_truth_${i}/annotation.xml' &&
            #end if
        #end for

        ketos
            @GLOBAL_ARGS@
            compile
            --output dataset.arrow
            --format-type '$training_data.format_type'
            $empty_lines
            --recordbatch-size '$recordbatch_size'
            #if str($force_type).strip() and str($force_type) != 'None'
                --force-type '$force_type'
            #end if
            #if $legacy_polygons
                --legacy-polygons
            #end if

            #for $i, $pair in enumerate($pairs)
                #if $training_data.format_type == 'path'
                    #if $input_source.source == 'repeat'
                        #set $image = $pair.image
                    #else
                        #set $image = $pair.forward
                    #end if
                    'ground_truth_${i}.${image.ext}'
                #else
                    'ground_truth_${i}/annotation.xml'
                #end if
            #end for
    ]]></command>

    <expand macro="env_vars"/>

    <inputs>
        <expand macro="global_inputs"/>

        <conditional name="training_data">
            <param name="format_type"
                   type="select"
                   label="Training data format">
                <option value="alto" selected="true">ALTO</option>
                <option value="page">PAGE XML</option>
                <option value="path">Line image/transcription pairs</option>
            </param>
            <expand macro="compile_training_data_inputs"/>
        </conditional>

        <param argument="--force-type"
               type="select"
               optional="true"
               label="Force dataset type">
            <option value="" selected="true">Auto-detect</option>
            <option value="bbox">Bounding boxes</option>
            <option value="baseline">Baselines</option>
        </param>

        <param name="empty_lines"
               type="select"
               label="Empty text lines">
            <option value="--skip-empty-lines" selected="true">
                Skip empty lines
            </option>
            <option value="--keep-empty-lines">
                Keep empty lines
            </option>
        </param>

        <param argument="--recordbatch-size"
               type="integer"
               min="1"
               value="100"
               label="Minimum records per Arrow RecordBatch"/>

        <param argument="--legacy-polygons"
               type="boolean"
               truevalue="true"
               falsevalue="false"
               checked="false"
               label="Use legacy polygon extractor"/>
    </inputs>

    <outputs>
        <data name="dataset"
              format="arrow"
              from_work_dir="dataset.arrow"
              label="${tool.name} on ${on_string}: dataset.arrow"/>
    </outputs>

    <tests>
        <!-- Test manual repeat input using defaults. -->
        <test expect_num_outputs="1">
            <conditional name="training_data">
                <param name="format_type" value="path"/>

                <conditional name="input_source">
                    <param name="source" value="repeat"/>

                    <repeat name="ground_truth_pairs">
                        <param name="image"
                               value="compile_input_line.png"
                               ftype="png"/>
                        <param name="transcription"
                               value="compile_input_line.gt.txt"
                               ftype="txt"/>
                    </repeat>
                </conditional>
            </conditional>

            <param name="empty_lines" value="--skip-empty-lines"/>
            <param name="recordbatch_size" value="100"/>

            <output name="dataset" ftype="arrow">
                <assert_contents>
                    <has_size min="100"/>
                    <has_text text="ARROW1" n="2"/>
                </assert_contents>
            </output>

            <assert_stdout>
                <has_text text="Output file written to dataset.arrow"/>
            </assert_stdout>
        </test>

          <!-- Test ALTO input from a list:paired collection. -->
        <test expect_num_outputs="1">
            <conditional name="training_data">
                <param name="format_type" value="alto"/>

                <conditional name="input_source">
                    <param name="source" value="collection"/>

                    <param name="ground_truth_collection">
                        <collection type="list:paired">
                            <element name="page_001">
                                <collection type="paired">
                                    <element name="forward"
                                             value="input_binarized.png"
                                             ftype="png"/>
                                    <element name="reverse"
                                             value="input_binarized_ocr_output.alto"
                                             ftype="alto"/>
                                </collection>
                            </element>
                        </collection>
                    </param>
                </conditional>
            </conditional>

            <param name="empty_lines" value="--skip-empty-lines"/>
            <param name="recordbatch_size" value="100"/>

            <output name="dataset" ftype="arrow">
                <assert_contents>
                    <has_size min="100"/>
                    <has_text text="ARROW1" n="2"/>
                </assert_contents>
            </output>
        </test>

        <!-- Test a list:paired collection and non-default options. -->
        <test expect_num_outputs="1">
            <conditional name="training_data">
                <param name="format_type" value="path"/>

                <conditional name="input_source">
                    <param name="source" value="collection"/>

                    <param name="ground_truth_collection">
                        <collection type="list:paired">
                            <element name="line_001">
                                <collection type="paired">
                                    <element name="forward"
                                             value="compile_input_line.png"
                                             ftype="png"/>
                                    <element name="reverse"
                                             value="compile_input_line.gt.txt"
                                             ftype="txt"/>
                                </collection>
                            </element>

                            <element name="line_002">
                                <collection type="paired">
                                    <element name="forward"
                                             value="compile_input_line.png"
                                             ftype="png"/>
                                    <element name="reverse"
                                             value="compile_input_line.gt.txt"
                                             ftype="txt"/>
                                </collection>
                            </element>
                        </collection>
                    </param>
                </conditional>
            </conditional>

            <param name="force_type" value="bbox"/>
            <param name="empty_lines" value="--keep-empty-lines"/>
            <param name="recordbatch_size" value="1"/>
            <param name="legacy_polygons" value="true"/>

            <output name="dataset" ftype="arrow">
                <assert_contents>
                    <has_size min="100"/>
                    <has_text text="ARROW1" n="2"/>
                </assert_contents>
            </output>
        </test>

        <!-- Test PAGE XML input from a list:paired collection. -->
        <test expect_num_outputs="1">
            <conditional name="training_data">
                <param name="format_type" value="page"/>

                <conditional name="input_source">
                    <param name="source" value="collection"/>

                    <param name="ground_truth_collection">
                        <collection type="list:paired">
                            <element name="page_001">
                                <collection type="paired">
                                    <element name="forward"
                                             value="input_binarized.png"
                                             ftype="png"/>
                                    <element name="reverse"
                                             value="input_binarized_ocr_output.page.xml"
                                             ftype="page.xml"/>
                                </collection>
                            </element>
                        </collection>
                    </param>
                </conditional>
            </conditional>

            <param name="empty_lines" value="--skip-empty-lines"/>
            <param name="recordbatch_size" value="100"/>

            <output name="dataset" ftype="arrow">
                <assert_contents>
                    <has_size min="100"/>
                    <has_text text="ARROW1" n="2"/>
                </assert_contents>
            </output>
        </test>


        <!-- Test ALTO input with its referenced page image. -->
        <test expect_num_outputs="1">
            <conditional name="training_data">
                <param name="format_type" value="alto"/>

                <conditional name="input_source">
                    <param name="source" value="repeat"/>

                    <repeat name="ground_truth_pairs">
                        <param name="image"
                               value="input_binarized.png"
                               ftype="png"/>
                        <param name="annotation"
                               value="input_binarized_ocr_output.alto"
                               ftype="alto"/>
                    </repeat>
                </conditional>
            </conditional>

            <param name="empty_lines" value="--skip-empty-lines"/>
            <param name="recordbatch_size" value="100"/>

            <output name="dataset" ftype="arrow">
                <assert_contents>
                    <has_size min="100"/>
                    <has_text text="ARROW1" n="2"/>
                </assert_contents>
            </output>
        </test>

        <!-- Test PAGE XML input with its referenced page image. -->
        <test expect_num_outputs="1">
            <conditional name="training_data">
                <param name="format_type" value="page"/>

                <conditional name="input_source">
                    <param name="source" value="repeat"/>

                    <repeat name="ground_truth_pairs">
                        <param name="image"
                               value="input_binarized.png"
                               ftype="png"/>
                        <param name="annotation"
                               value="input_binarized_ocr_output.page.xml"
                               ftype="page.xml"/>
                    </repeat>
                </conditional>
            </conditional>

            <param name="empty_lines" value="--skip-empty-lines"/>
            <param name="recordbatch_size" value="100"/>

            <output name="dataset" ftype="arrow">
                <assert_contents>
                    <has_size min="100"/>
                    <has_text text="ARROW1" n="2"/>
                </assert_contents>
            </output>
        </test>
    </tests>

    <help format="markdown"><![CDATA[
Compiles OCR ground-truth data into Kraken/Ketos' the Apache Arrow
IPC dataset format.

For line image/transcription input, either select individual pairs or provide
a `list:paired` Galaxy collection. In a collection, each `forward` element must
be the line image and each `reverse` element must be its text transcription.

Use the resulting dataset with Ketos training commands by selecting the
compiled arrow training-data format.
    ]]></help>

    <expand macro="citations"/>
</tool>
