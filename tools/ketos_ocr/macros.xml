<macros>
    <token name="@TOOL_VERSION@">7.0.2</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.1</token>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">kraken-ocr</requirement>
        </requirements>
    </xml>
    <xml name="creators">
        <creator>
            <person givenName="Ivo Christopher" familyName="Leist" email="leist@informatik.uni-freiburg.de" identifier="https://orcid.org/0000-0002-9772-443X"/>
            <organization name="AI4SOCIAL+" url="https://cordis.europa.eu/project/id/101292886"/>
        </creator>
    </xml>
    <xml name="env_vars">
        <environment_variables>
            <environment_variable name="TERM">dumb</environment_variable>
            <environment_variable name="FORCE_COLOR">0</environment_variable>
            <environment_variable name="TORCHINDUCTOR_CACHE_DIR">\$_GALAXY_JOB_TMP_DIR</environment_variable>
        </environment_variables>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.16995/dscn.8094</citation>
        </citations>
    </xml>
    <token name="@GLOBAL_ARGS@"><![CDATA[
        #if str($global.config).strip() and str($global.config) != 'None'
            --config '$global.config'
        #end if
        #if str($global.device).strip() and str($global.device) != 'None'
            --device '$global.device'
        #end if
        #if str($global.precision).strip() and str($global.precision) != 'None'
            --precision '$global.precision'
        #end if
        #if str($global.workers).strip() and str($global.workers) != 'None'
            --workers '$global.workers'
        #end if
        #if str($global.threads).strip() and str($global.threads) != 'None'
            --threads '$global.threads'
        #end if
        #if str($global.seed).strip() and str($global.seed) != 'None'
            --seed '$global.seed'
        #end if
        $global.deterministic
    ]]></token>
    <token name="@TRAINING_ARGS@"><![CDATA[
        --output model
        --weights-format safetensors
        #if str($train_opts.batch_size).strip() and str($train_opts.batch_size) != 'None'
            --batch-size '$train_opts.batch_size'
        #end if
        #if $train_opts.initialization.source == 'load'
            --load '$train_opts.initialization.model'
        #elif $train_opts.initialization.source == 'resume'
            --resume '$train_opts.initialization.checkpoint'
        #end if
        #if str($train_opts.freq).strip() and str($train_opts.freq) != 'None'
            --freq '$train_opts.freq'
        #end if
        #if str($train_opts.quit).strip() and str($train_opts.quit) != 'None'
            --quit '$train_opts.quit'
        #end if
        #if str($train_opts.epochs).strip() and str($train_opts.epochs) != 'None'
            --epochs '$train_opts.epochs'
        #end if
        #if str($train_opts.min_epochs).strip() and str($train_opts.min_epochs) != 'None'
            --min-epochs '$train_opts.min_epochs'
        #end if
        #if str($train_opts.lag).strip() and str($train_opts.lag) != 'None'
            --lag '$train_opts.lag'
        #end if
        #if str($train_opts.min_delta).strip() and str($train_opts.min_delta) != 'None'
            --min-delta '$train_opts.min_delta'
        #end if
        #if str($train_opts.optimizer).strip() and str($train_opts.optimizer) != 'None'
            --optimizer '$train_opts.optimizer'
        #end if
        #if str($train_opts.lrate).strip() and str($train_opts.lrate) != 'None'
            --lrate '$train_opts.lrate'
        #end if
        #if str($train_opts.momentum).strip() and str($train_opts.momentum) != 'None'
            --momentum '$train_opts.momentum'
        #end if
        #if str($train_opts.weight_decay).strip() and str($train_opts.weight_decay) != 'None'
            --weight-decay '$train_opts.weight_decay'
        #end if
        #if str($train_opts.gradient_clip_val).strip() and str($train_opts.gradient_clip_val) != 'None'
            --gradient-clip-val '$train_opts.gradient_clip_val'
        #end if
        #if str($train_opts.accumulate_grad_batches).strip() and str($train_opts.accumulate_grad_batches) != 'None'
            --accumulate-grad-batches '$train_opts.accumulate_grad_batches'
        #end if
        #if str($train_opts.warmup).strip() and str($train_opts.warmup) != 'None'
            --warmup '$train_opts.warmup'
        #end if
        #if str($train_opts.schedule).strip() and str($train_opts.schedule) != 'None'
            --schedule '$train_opts.schedule'
        #end if
        #if str($train_opts.gamma).strip() and str($train_opts.gamma) != 'None'
            --gamma '$train_opts.gamma'
        #end if
        #if str($train_opts.step_size).strip() and str($train_opts.step_size) != 'None'
            --step-size '$train_opts.step_size'
        #end if
        #if str($train_opts.sched_patience).strip() and str($train_opts.sched_patience) != 'None'
            --sched-patience '$train_opts.sched_patience'
        #end if
        #if str($train_opts.cos_max).strip() and str($train_opts.cos_max) != 'None'
            --cos-max '$train_opts.cos_max'
        #end if
        #if str($train_opts.cos_min_lr).strip() and str($train_opts.cos_min_lr) != 'None'
            --cos-min-lr '$train_opts.cos_min_lr'
        #end if
        #if str($train_opts.partition).strip() and str($train_opts.partition) != 'None'
            --partition '$train_opts.partition'
        #end if
        #if str($train_opts.augment).strip() and str($train_opts.augment) != 'None'
            $train_opts.augment
        #end if
        #if $train_opts.logger.enabled == 'yes'
            --logger '$train_opts.logger.kind'
            --log-dir logs
        #end if
    ]]></token>
    <token name="@GROUND_TRUTH_ARGS@"><![CDATA[
        #for $item in $ground_truth
            #if str($item).strip() and str($item) != 'None'
                '$item'
            #end if
        #end for
    ]]></token>
    <token name="@TRAINING_DATA_ARGS@"><![CDATA[
        #for $item in $training_data
            #if str($item).strip() and str($item) != 'None'
                --training-data '$item'
            #end if
        #end for
        #for $item in $evaluation_data
            #if str($item).strip() and str($item) != 'None'
                --evaluation-data '$item'
            #end if
        #end for
    ]]></token>
    <token name="@TEST_SET_ARGS@"><![CDATA[
        #for $item in $test_set
            #if str($item).strip() and str($item) != 'None'
                '$item'
            #end if
        #end for
    ]]></token>
    <token name="@TEST_DATA_ARGS@"><![CDATA[
        #for $item in $test_data
            #if str($item).strip() and str($item) != 'None'
                --test-data '$item'
            #end if
        #end for
    ]]></token>
    <token name="@CAPTURE_TRAINING_OUTPUTS@"><![CDATA[
        best_model=\$(find model -maxdepth 1 -type f -name 'best_*.safetensors' | head -n 1) &&
        if [ -n "\$best_model" ]; then cp "\$best_model" best_model.weights; fi
    ]]></token>
    <xml name="global_inputs">
        <section name="global" title="Global Ketos options" expanded="false">
            <param name="config" type="data" format="yaml" optional="true" label="Experiment YAML configuration" help="Optional ketos --config file. Command-line options selected below are still passed explicitly."/>
            <param argument="--device" type="text" optional="true" label="Device" help="Examples: cpu, cuda:0, mps, auto"/>
            <param argument="--precision" type="select" optional="true" label="Numerical precision">
                <option value="" selected="true">Use Ketos default</option>
                <option value="64-true">64-bit</option>
                <option value="32-true">32-bit</option>
                <option value="16-mixed">16-bit mixed</option>
                <option value="bf16-mixed">bfloat16 mixed</option>
            </param>
            <param argument="--workers" type="integer" optional="true" min="0" label="Data loading worker processes"/>
            <param argument="--threads" type="integer" optional="true" min="1" label="OpenMP/BLAS thread limit"/>
            <param argument="--seed" type="integer" optional="true" label="Random seed"/>
            <param name="deterministic" type="select" label="Deterministic training">
                <option value="" selected="true">Use Ketos default</option>
                <option value="--deterministic">Enable</option>
                <option value="--no-deterministic">Disable</option>
            </param>
        </section>
    </xml>
    <xml name="training_inputs">
        <section name="train_opts" title="Training options" expanded="false">
            <conditional name="initialization">
                <param name="source" type="select" label="Initialization">
                    <option value="new" selected="true">Train a new model</option>
                    <option value="load">Load existing weights/checkpoint for a fresh run</option>
                    <option value="resume">Resume a checkpointed run</option>
                </param>
                <when value="new"/>
                <when value="load">
                    <param name="model" type="data" format="binary,safetensors" label="Existing model or checkpoint"/>
                </when>
                <when value="resume">
                    <param name="checkpoint" type="data" format="binary" label="Checkpoint to resume"/>
                </when>
            </conditional>
            <param argument="--batch-size" type="integer" optional="true" min="1" label="Batch sample size"/>
            <param argument="--freq" type="float" optional="true" min="0" label="Validation/report frequency in epochs"/>
            <param argument="--quit" type="select" optional="true" label="Stop condition">
                <option value="" selected="true">Use Ketos default</option>
                <option value="early">Early stopping</option>
                <option value="fixed">Fixed epoch count</option>
                <option value="aneal">Aneal</option>
            </param>
            <param argument="--epochs" type="integer" optional="true" min="1" label="Epochs"/>
            <param argument="--min-epochs" type="integer" optional="true" min="0" label="Minimum epochs"/>
            <param argument="--lag" type="integer" optional="true" min="0" label="Early stopping lag"/>
            <param argument="--min-delta" type="float" optional="true" min="0" label="Minimum validation improvement"/>
            <param argument="--optimizer" type="select" optional="true" label="Optimizer">
                <option value="" selected="true">Use Ketos default</option>
                <option value="Adam">Adam</option>
                <option value="SGD">SGD</option>
                <option value="RMSprop">RMSprop</option>
                <option value="Lamb">Lamb</option>
                <option value="AdamW">AdamW</option>
            </param>
            <param argument="--lrate" type="float" optional="true" min="0" label="Learning rate"/>
            <param argument="--momentum" type="float" optional="true" min="0" label="Momentum"/>
            <param argument="--weight-decay" type="float" optional="true" min="0" label="Weight decay"/>
            <param argument="--gradient-clip-val" type="float" optional="true" min="0" label="Gradient clip value"/>
            <param argument="--accumulate-grad-batches" type="integer" optional="true" min="1" label="Gradient accumulation batches"/>
            <param argument="--warmup" type="integer" optional="true" min="0" label="Warmup steps/samples"/>
            <param argument="--schedule" type="select" optional="true" label="Learning-rate schedule">
                <option value="" selected="true">Use Ketos default</option>
                <option value="constant">constant</option>
                <option value="1cycle">1cycle</option>
                <option value="exponential">exponential</option>
                <option value="step">step</option>
                <option value="reduceonplateau">reduceonplateau</option>
                <option value="cosine">cosine</option>
                <option value="cosine_warm_restarts">cosine_warm_restarts</option>
            </param>
            <param argument="--gamma" type="float" optional="true" min="0" label="Schedule decay factor"/>
            <param argument="--step-size" type="float" optional="true" min="0" label="Schedule step size"/>
            <param argument="--sched-patience" type="integer" optional="true" min="0" label="Reduce-on-plateau patience"/>
            <param argument="--cos-max" type="integer" optional="true" min="0" label="Cosine schedule max epoch"/>
            <param argument="--cos-min-lr" type="float" optional="true" min="0" label="Cosine schedule minimum learning rate"/>
            <param argument="--partition" type="float" optional="true" min="0" max="1" label="Training/validation partition"/>
            <param name="augment" type="select" label="Image augmentation">
                <option value="" selected="true">Use Ketos default</option>
                <option value="--augment">Enable</option>
                <option value="--no-augment">Disable</option>
            </param>
            <conditional name="logger">
                <param name="enabled" type="select" label="Metric logger">
                    <option value="no" selected="true">Disabled</option>
                    <option value="yes">Enabled</option>
                </param>
                <when value="no"/>
                <when value="yes">
                    <param name="kind" type="select" label="Logger backend">
                        <option value="tensorboard" selected="true">tensorboard</option>
                        <option value="wandb">wandb</option>
                    </param>
                </when>
            </conditional>
        </section>
    </xml>
    <xml name="training_data_inputs">
        <param name="ground_truth" type="data" multiple="true" optional="true" format="txt,xml,alto,json,jpg,png,tiff,binary" label="Ground-truth files passed as positional arguments"/>
        <param name="training_data" type="data" multiple="true" optional="true" format="txt" label="Training manifest files" help="Passed with --training-data."/>
        <param name="evaluation_data" type="data" multiple="true" optional="true" format="txt" label="Evaluation manifest files" help="Passed with --evaluation-data."/>
    </xml>
    <xml name="training_outputs">
        <data name="best_model" format="binary" from_work_dir="best_model.weights" label="${tool.name} on ${on_string}: best model"/>
        <data name="report" format="txt" from_work_dir="training_report.txt" label="${tool.name} on ${on_string}: report"/>
        <collection name="checkpoints" type="list" label="${tool.name} on ${on_string}: checkpoints">
            <discover_datasets pattern="(?P&lt;designation&gt;.+)\.ckpt" directory="model" format="binary"/>
        </collection>
    </xml>
    <xml name="compile_training_data_input"
         tokens="format_type,pair_label,unit,image_label,annotation_name,annotation_format,annotation_label,collection_label,collection_help">
        <when value="@FORMAT_TYPE@">
            <conditional name="input_source">
                <param name="source"
                       type="select"
                       label="Input method">
                    <option value="repeat" selected="true">
                        Select individual @PAIR_LABEL@ pairs
                    </option>
                    <option value="collection">
                        List of paired datasets
                    </option>
                </param>

                <when value="repeat">
                    <repeat name="ground_truth_pairs"
                            title="Ground-truth @UNIT@"
                            min="1">
                        <param name="image"
                               type="data"
                               format="jpg,png,tiff"
                               label="@IMAGE_LABEL@"/>

                        <param name="@ANNOTATION_NAME@"
                               type="data"
                               format="@ANNOTATION_FORMAT@"
                               label="@ANNOTATION_LABEL@"/>
                    </repeat>
                </when>

                <when value="collection">
                    <param name="ground_truth_collection"
                           type="data_collection"
                           collection_type="list:paired"
                           format="jpg,png,tiff,@ANNOTATION_FORMAT@"
                           label="@COLLECTION_LABEL@"
                           help="@COLLECTION_HELP@"/>
                </when>
            </conditional>
        </when>
    </xml>

    <xml name="compile_training_data_inputs">
        <expand macro="compile_training_data_input"
                format_type="path"
                pair_label="image/transcription"
                unit="line"
                image_label="Line image"
                annotation_name="transcription"
                annotation_format="txt"
                annotation_label="Ground-truth transcription"
                collection_label="Line image/transcription pairs"
                collection_help="For every pair, the forward element must be the line image and the reverse element must be its text transcription."/>

        <expand macro="compile_training_data_input"
                format_type="alto"
                pair_label="image/ALTO"
                unit="page"
                image_label="Page image"
                annotation_name="annotation"
                annotation_format="alto"
                annotation_label="ALTO annotation"
                collection_label="Page image/ALTO pairs"
                collection_help="For every pair, the forward element must be the page image and the reverse element must be its ALTO annotation."/>

        <expand macro="compile_training_data_input"
                format_type="page"
                pair_label="image/PAGE"
                unit="page"
                image_label="Page image"
                annotation_name="annotation"
                annotation_format="page.xml"
                annotation_label="PAGE annotation"
                collection_label="Page image/PAGE pairs"
                collection_help="For every pair, the forward element must be the page image and the reverse element must be its PAGE annotation."/>
    </xml>
</macros>
