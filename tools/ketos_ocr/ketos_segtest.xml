<tool id="ketos_segtest" name="Ketos Segtest" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>evaluate segmentation models</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <command detect_errors="exit_code"><![CDATA[
        ketos
            @GLOBAL_ARGS@
            segtest
            --model '$model'
            --format-type '$format_type'
            #if str($bl_tol).strip() and str($bl_tol) != 'None'
                --bl-tol '$bl_tol'
            #end if
            --test-class-mapping-mode '$test_class_mapping_mode'
            @TEST_DATA_ARGS@
            @TEST_SET_ARGS@
            > test_report.txt 2>&1 &&
        cat test_report.txt
    ]]></command>
    <expand macro="env_vars"/>
    <inputs>
        <expand macro="global_inputs"/>
        <param argument="--model" type="data" format="binary,safetensors" label="Segmentation model to evaluate"/>
        <param name="test_set" type="data" multiple="true" optional="true" format="xml,alto" label="Test set files passed as positional arguments"/>
        <param name="test_data" type="data" multiple="true" optional="true" format="txt" label="Test manifest files" help="Passed with --test-data."/>
        <param argument="--format-type" type="select" label="Test data format">
            <option value="xml" selected="true">XML</option>
            <option value="alto">ALTO</option>
            <option value="page">PageXML</option>
        </param>
        <param argument="--bl-tol" type="float" optional="true" min="0" label="Baseline detection metric tolerance in pixels"/>
        <param argument="--test-class-mapping-mode" type="select" label="Class mapping mode for test data">
            <option value="full" selected="true">full</option>
            <option value="canonical">canonical</option>
            <option value="custom">custom</option>
        </param>
    </inputs>
    <outputs>
        <data name="report" format="txt" from_work_dir="test_report.txt" label="${tool.name} on ${on_string}: report"/>
    </outputs>
    <tests>
        <test expect_failure="true">
            <param name="model" value="invalid_model.bin" ftype="binary"/>
            <param name="test_set" value="page.xml" ftype="xml"/>
            <param name="test_data" value="manifest.txt" ftype="txt"/>
            <param name="format_type" value="page"/>
            <param name="bl_tol" value="4"/>
            <param name="test_class_mapping_mode" value="canonical"/>
            <assert_command>
                <has_text text="segtest"/>
                <has_text text="--model"/>
                <has_text text="--format-type 'page'"/>
                <has_text text="--bl-tol '4.0'"/>
                <has_text text="--test-class-mapping-mode 'canonical'"/>
                <has_text text="--test-data"/>
            </assert_command>
        </test>
    </tests>
    <help format="markdown">
Evaluates a Kraken segmentation model and returns the textual Ketos report with segmentation metrics and class diagnostics.
    </help>
    <expand macro="citations"/>
</tool>
