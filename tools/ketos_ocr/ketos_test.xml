<tool id="ketos_test" name="Ketos Test" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>evaluate recognition models</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <command detect_errors="exit_code"><![CDATA[
        ketos
            @GLOBAL_ARGS@
            test
            --model '$model'
            --format-type '$format_type'
            #if str($batch_size).strip()
                --batch-size '$batch_size'
            #end if
            #if str($pad).strip()
                --pad '$pad'
            #end if
            #if str($normalization).strip()
                --normalization '$normalization'
            #end if
            #if str($normalize_whitespace).strip()
                $normalize_whitespace
            #end if
            #if str($reorder).strip()
                $reorder
                #if $reorder == '--reorder'
                    --base-dir '$base_dir'
                #end if
            #end if
            #if $no_legacy_polygons
                --no-legacy-polygons
            #end if
            @TEST_DATA_ARGS@
            @TEST_SET_ARGS@
            > test_report.txt 2>&1 &&
        cat test_report.txt
    ]]></command>
    <expand macro="env_vars"/>
    <inputs>
        <expand macro="global_inputs"/>
        <param argument="--model" type="data" format="binary,safetensors" label="Recognition model to evaluate"/>
        <param name="test_set" type="data" multiple="true" optional="true" format="txt,xml,alto,json,jpg,png,tiff,binary" label="Test set files passed as positional arguments"/>
        <param name="test_data" type="data" multiple="true" optional="true" format="txt" label="Test manifest files" help="Passed with --test-data."/>
        <param argument="--format-type" type="select" label="Test data format">
            <option value="path" selected="true">Path/image pairs</option>
            <option value="xml">XML</option>
            <option value="alto">ALTO</option>
            <option value="page">PageXML</option>
            <option value="binary">Compiled binary dataset</option>
        </param>
        <param argument="--batch-size" type="integer" optional="true" min="1" label="Batch sample size"/>
        <param argument="--pad" type="integer" optional="true" min="0" label="Left/right padding around lines"/>
        <param argument="--normalization" type="select" optional="true" label="Ground-truth Unicode normalization">
            <option value="" selected="true">Use Ketos default</option>
            <option value="NFD">NFD</option>
            <option value="NFKD">NFKD</option>
            <option value="NFC">NFC</option>
            <option value="NFKC">NFKC</option>
        </param>
        <param name="normalize_whitespace" type="select" label="Normalize Unicode whitespace">
            <option value="" selected="true">Use Ketos default</option>
            <option value="--normalize-whitespace">Enable</option>
            <option value="--no-normalize-whitespace">Disable</option>
        </param>
        <param name="reorder" type="select" label="Apply Unicode BiDi reordering">
            <option value="" selected="true">Use Ketos default</option>
            <option value="--reorder">Enable</option>
            <option value="--no-reorder">Disable</option>
        </param>
        <param argument="--base-dir" type="select" label="Base text direction for BiDi reordering">
            <option value="auto" selected="true">Auto</option>
            <option value="L">Left-to-right</option>
            <option value="R">Right-to-left</option>
        </param>
        <param argument="--no-legacy-polygons" type="boolean" truevalue="true" falsevalue="false" checked="false" label="Disable legacy polygon extractor"/>
    </inputs>
    <outputs>
        <data name="report" format="txt" from_work_dir="test_report.txt" label="${tool.name} on ${on_string}: report"/>
    </outputs>
    <tests>
        <test expect_failure="true">
            <param name="model" value="README.md" ftype="binary"/>
        </test>
    </tests>
    <help format="markdown">
Evaluates a Kraken recognition model and returns the textual Ketos report containing character and word error metrics.
    </help>
    <expand macro="citations"/>
</tool>
