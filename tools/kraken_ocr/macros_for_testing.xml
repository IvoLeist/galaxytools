<macros>
    <!-- Macros for testing _binarize -->
    <macro name="assert_binarized" token_width="1456" token_height="2184">
        <assert_contents>
            <has_image_channels channels="1"/>
            <has_image_width width="@WIDTH@"/>
            <has_image_height height="@HEIGHT@"/>
        </assert_contents>
    </macro>
    <macro name="assert_binarized_pdf">
        <expand macro="assert_binarized" width="1875" height="2812"/>
    </macro>
    <!-- Macros for testing _segment & _ocr -->
    <!-- The test model are too large to include in the repository.
        Thus pulled from a commit-pinned GitHub URL. Zenodo cannot be used here 
        because the models is only available inside a ZIP archive. -->
    <token name="@BASE_URL@">https://raw.githubusercontent.com</token>
    <!-- model bdd-segmentation-regions-1.0: 4.3 MB -->
    <token name="@SEG_MODEL_REPO_PATH@">michaelscho/bdd-segmentation-regions</token>
    <token name="@SEG_MODEL_COMMIT_HASH@">b818488376bc635f1a121427979b33dfc11638df</token>
    <token name="@SEG_MODEL_FILENAME@">bdd-segmentation-regions-1.0.mlmodel</token>
    <token name="@SEG_MODEL_URL@">@BASE_URL@/@SEG_MODEL_REPO_PATH@/@SEG_MODEL_COMMIT_HASH@/@SEG_MODEL_FILENAME@</token>
    <!-- model catmus-print-fondue-large: 21.8 MB -->
    <token name="@DOC_OCR_MODEL_REPO_PATH@">obtic-sorbonne/Toolbox-site</token>
    <token name="@DOC_OCR_MODEL_COMMIT_HASH@">e88184cbb0ed99ea80c63fd606d7764fbd22df72</token>
    <token name="@DOC_OCR_MODEL_FILENAME@">catmus-print-fondue-large.mlmodel</token>
    <token name="@DOC_OCR_MODEL_FILEPATH@">kraken_models/ocr_models/@DOC_OCR_MODEL_FILENAME@</token>
    <token name="@DOC_OCR_MODEL_URL@">@BASE_URL@/@DOC_OCR_MODEL_REPO_PATH@/@DOC_OCR_MODEL_COMMIT_HASH@/@DOC_OCR_MODEL_FILEPATH@</token>
    <!-- model greek-english_porson_sophoclesplaysa05campgoog: 16.9 MB -->
    <token name="@LINE_OCR_MODEL_REPO_PATH@">AjaxMultiCommentary/OCR-kraken-models</token>
    <token name="@LINE_OCR_MODEL_COMMIT_HASH@">e187951d0ebc669929c866f8a43bc303e849ff45</token>
    <token name="@LINE_OCR_MODEL_FILENAME@">greek-english_porson_sophoclesplaysa05campgoog.mlmodel</token>
    <token name="@LINE_OCR_MODEL_FILEPATH@">kraken-models/greek-english_porson_sophoclesplaysa05campgoog/@LINE_OCR_MODEL_FILENAME@</token>
    <token name="@LINE_OCR_MODEL_URL@">@BASE_URL@/@LINE_OCR_MODEL_REPO_PATH@/@LINE_OCR_MODEL_COMMIT_HASH@/@LINE_OCR_MODEL_FILEPATH@</token>
    <!-- XML assert namespaces -->
    <token name="@NS_ALTO@">{http://www.loc.gov/standards/alto/ns-v4#}</token>
    <token name="@NS_PAGE@">{http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15}</token>
    <token name="@NS_ABBYY@">{http://www.abbyy.com/FineReader_xml/FineReader10-schema-v1.xml}</token>
    <macro name="load_model_in_history" tokens="model_name,model_url">
        <conditional name="model_source">
            <param name="source" value="history"/>
            <param name="model" value="@MODEL_NAME@" location="@MODEL_URL@" ftype="mlmodel"/>
        </conditional>
    </macro>
    <macro name="get_segmentation_model">
        <expand macro="load_model_in_history" model_name="@SEG_MODEL_NAME@" model_url="@SEG_MODEL_URL@"/>
    </macro>
    <macro name="get_document_ocr_model">
        <expand macro="load_model_in_history" model_name="@DOC_OCR_MODEL_FILENAME@" model_url="@DOC_OCR_MODEL_URL@"/>
    </macro>
    <macro name="get_line_ocr_model">
        <expand macro="load_model_in_history" model_name="@LINE_OCR_MODEL@" model_url="@LINE_OCR_MODEL_URL@"/>
    </macro>
    <macro name="use_presegmented_input" tokens="segmentation,segmentation_ftype" token_image="input_binarized.png" token_image_ftype="png">
        <conditional name="input_type">
            <param name="source" value="segmented"/>
            <param name="image" value="@IMAGE@" ftype="@IMAGE_FTYPE@"/>
            <param name="segmentation" value="@SEGMENTATION@" ftype="@SEGMENTATION_FTYPE@"/>
        </conditional>
    </macro>
    <macro name="use_line_input" tokens="image,image_ftype">
        <conditional name="input_type">
            <param name="source" value="line"/>
            <param name="image" value="@IMAGE@" ftype="@IMAGE_FTYPE@"/>
        </conditional>
    </macro>
    <macro name="test_bidi_reordering" tokens="mode,bidi_value">
        <test expect_num_outputs="1">
            <expand macro="use_presegmented_input" segmentation="input_binarized_seg_alto.xml" segmentation_ftype="alto"/>
            <expand macro="get_document_ocr_model"/>
            <conditional name="reordering">
                <param name="mode" value="@MODE@"/>
                <yield/>
            </conditional>
            <param name="output_format_flag" value="-a"/>
            <output name="output" ftype="alto">
                <assert_contents>
                    <xml_element path=".//@NS_ALTO@processingStepSettings">
                        <has_text text="@DOC_OCR_MODEL_FILENAME@"/>
                        <has_text text="bidi_reordering: @BIDI_VALUE@"/>
                    </xml_element>
                </assert_contents>
            </output>
        </test>
    </macro>
</macros>
