<macros>
    <token name="@VERBOSE_FLAGS@"><![CDATA[
        #if int($verbose) > 0
            #for $i in range(int($verbose))
                -v
            #end for
        #end if
    ]]></token>
    <xml name="verbose_param">
        <param name="verbose" type="integer" min="0" max="3" value="0" label="Verbosity level" help="Increase logging verbosity. 0=default; higher values add one -v flag per level."/>
    </xml>
    <token name="@RUN_KRAKEN_OCR@"><![CDATA[
        kraken
            -vvv
            $output_format_flag
            --raise-on-error

            #if $input_type.source == 'segmented'
                --format-type '${segmentation_ext}'
                --input 'segmentation.${segmentation_ext}' 'kraken_output.${out_ext}'
            #else
                #if $input_type.image.ext == 'pdf'
                    --format-type pdf
                    --batch-input 'input.${input_type.image.ext}'
                    --suffix .${out_ext}
                #else
                    --input 'input.${input_type.image.ext}' 'kraken_output.${out_ext}'
                #end if
            #end if

            ocr
    ]]></token>
</macros>
