<tool id="kraken_ocr" name="Kraken OCR" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>extract text from segmented or line document images</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <command detect_errors="exit_code"><![CDATA[
        #if $output_format_flag == '-h'
            #set $out_ext = 'html'
        #elif $output_format_flag == '-n'
            #set $out_ext = 'txt'
        #else
            #set $out_ext = 'xml'
        #end if
        @REJECT_MULTIPAGE_TIFF_BASED_ON_FILE_METADATA@

        ln -s '$input_type.image' 'input.${input_type.image.ext}' &&
        #if $input_type.source == 'segmented'
           #set $segmentation_ext = 'xml'
            ln -s '$input_type.segmentation' 'segmentation.${segmentation_ext}' &&
        #end if

        #if $input_type.image.ext != 'pdf'
            ln -s '$output' 'kraken_output.${out_ext}' &&
        #end if

        #if $model_source.source == 'history'
            #set $model_name = str($model_source.model.name)
            ln -s '$model_source.model' '$model_name' &&
        #end if

        @RUN_KRAKEN_OCR@
            #if $model_source.source == 'datatable'
                --model '$model'
            #else
                --model '$model_name'
            #end if
            --pad '$pad'
            --temperature '$temperature'
            $reorder
            --base-dir '$base_dir'
            #if $input_type.source == 'line'
                --no-segmentation
            #end if
            --text-direction '$text_direction'
            #if $no_legacy_polygons
                --no-legacy-polygons
            #end if
    ]]></command>
    <expand macro="env_vars"/>
    <inputs>
        <conditional name="input_type">
            <param name="source" type="select" label="Input type" help="For non-line PDF input use Galaxy's Kraken OCR Pipeline tool">
                <option value="segmented" selected="true">Pre-segmented image</option>
                <option value="line">Single line image</option>
            </param>
            <when value="segmented">
                <param name="image" type="data" format="jpg,png,tiff" label="Image"/>
                <param name="segmentation" type="data" format="xml" label="Segmentation XML" help="File containing pre-segmented text regions in ALTO or PAGE format"/>
            </when>
            <when value="line">
                <param name="image" type="data" format="jpg,png,tiff,pdf" label="Line image"/>
            </when>
        </conditional>
        <conditional name="model_source">
            <param name="source" type="select" label="Model source" help="Select a model from the list or upload your own model file.">
                <option value="datatable" selected="true">Models served by Galaxy</option>
                <option value="history">Model from your Galaxy history</option>
            </param>
            <when value="datatable">
                <param name="model" type="select" label="OCR model" help="Optical character recognition model used by Kraken.">
                   <options from_data_table="ocr_ml_models">
                        <!-- returned value: .mlmodel path on your system/on Galaxy servers -->
                        <column name="value" index="5"/>
                        <!-- displayed label including variant: e.g. "CATMuS-Print [Tiny]" -->
                        <column name="name" index="4"/>
                        <!-- sorting by explicit sort key: e.g. "CATMuS-Print__010" -->
                        <filter type="sort_by" column="7"/>
                    </options>
                </param>
            </when>
            <when value="history">
                <param name="model" type="data" format="binary" label="OCR model" help="Kraken OCR model file from your history."/>
            </when>
        </conditional>
        <param name="output_format_flag" type="select" label="Output format">
            <option value="-a" selected="true">ALTO XML</option>
            <option value="-x">PageXML</option>
            <option value="-y">abbyyXML</option>
            <option value="-h">hOCR</option>
            <option value="-n">Text</option>
        </param>
        <param argument="--pad" type="integer" min="0" value="16" label="Padding to add around line images for OCR"/>
        <param argument="--temperature" type="float" value="1.0" label="Temperature for OCR sampling"/>
        <param name="reorder" type="select" label="Reorder lines with OCR text line reading order model">
            <option value="--reorder" selected="true">Yes</option>
            <option value="--no-reorder">No</option>
        </param>
        <param argument="--base-dir" type="text" value="L" label="Base text direction">
            <sanitizer>
                <valid initial="string.ascii_letters,string.digits">
                    <add value="-"/>
                    <add value="_"/>
                </valid>
            </sanitizer>
        </param>
        <param argument="--text-direction" type="select" label="OCR text direction">
            <option value="horizontal-tb" selected="true">Horizontal, top-to-bottom</option>
            <option value="vertical-lr">Vertical, left-to-right</option>
            <option value="vertical-rl">Vertical, right-to-left</option>
        </param>
        <param name="no_legacy_polygons" type="boolean" truevalue="true" falsevalue="false" checked="false" label="Disable legacy polygon output" help="Pass --no-legacy-polygons to Kraken."/>
    </inputs>
    <outputs>
        <data name="output" format="txt" label="${tool.name} on ${on_string}">
            <filter>input_type['image'].ext != "pdf"</filter>
            <actions>
                <conditional name="output_format_flag">
                    <when value="-a">
                        <action type="format" default="xml"/>
                    </when>
                    <when value="-x">
                        <action type="format" default="xml"/>
                    </when>
                    <when value="-h">
                        <action type="format" default="html"/>
                    </when>
                    <when value="-y">
                        <action type="format" default="xml"/>
                    </when>
                    <when value="-n">
                        <action type="format" default="txt"/>
                    </when>
                </conditional>
            </actions>
        </data>
        <collection name="pdf_output" type="list" label="${tool.name} pages on ${on_string}">
            <filter>input_type['image'].ext == "pdf"</filter>
            <discover_datasets pattern="(?P&lt;designation&gt;.+)\.(?P&lt;ext&gt;txt|xml|html)"/>
        </collection>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input_type|source" value="segmented"/>
            <param name="input_type|image" value="input_binarized.png" ftype="png"/>
            <param name="input_type|segmentation" value="input_binarized_seg_alto.xml" ftype="xml"/>
            <param name="model_source|source" value="history"/>
            <!-- The test model is too large (21.8 MB) to include in the repository.
                 Thus pulled from a commit-pinned GitHub URL. Zenodo cannot be used here 
                 because the model is only available inside a ZIP archive. -->
            <param name="model_source|model" value="catmus-print-fondue-large.mlmodel" location="https://raw.githubusercontent.com/obtic-sorbonne/Toolbox-site/e88184cbb0ed99ea80c63fd606d7764fbd22df72/kraken_models/ocr_models/catmus-print-fondue-large.mlmodel" ftype="binary"/>
            <param name="output_format_flag" value="-a"/>
            <output name="output" ftype="xml">
                <assert_contents>
                    <has_text text="alto"/>
                    <has_text text="catmus-print-fondue-large.mlmodel"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="input_type|source" value="segmented"/>
            <param name="input_type|image" value="input_binarized.png" ftype="png"/>
            <param name="input_type|segmentation" value="input_binarized_seg_page.xml" ftype="xml"/>
            <param name="model_source|source" value="history"/>
            <param name="model_source|model" value="catmus-print-fondue-large.mlmodel" location="https://raw.githubusercontent.com/obtic-sorbonne/Toolbox-site/e88184cbb0ed99ea80c63fd606d7764fbd22df72/kraken_models/ocr_models/catmus-print-fondue-large.mlmodel" ftype="binary"/>
            <param name="output_format_flag" value="-h"/>
            <output name="output" ftype="html">
                <assert_contents>
                    <has_text text="ocr_line"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="input_type|source" value="segmented"/>
            <param name="input_type|image" value="input_binarized.png" ftype="png"/>
            <param name="input_type|segmentation" value="input_binarized_seg_alto.xml" ftype="xml"/>
            <param name="model_source|source" value="history"/>
            <param name="model_source|model" value="catmus-print-fondue-large.mlmodel" location="https://raw.githubusercontent.com/obtic-sorbonne/Toolbox-site/e88184cbb0ed99ea80c63fd606d7764fbd22df72/kraken_models/ocr_models/catmus-print-fondue-large.mlmodel" ftype="binary"/>
            <param name="output_format_flag" value="-n"/>
            <param name="pad" value="0"/>
            <param name="temperature" value="0.8"/>
            <param name="reorder" value="--no-reorder"/>
            <param name="base_dir" value="L"/>
            <param name="text_direction" value="horizontal-tb"/>
            <param name="no_legacy_polygons" value="true"/>
            <output name="output" ftype="txt">
                <assert_contents>
                    <has_text text="HISTOIRE"/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="input_type|source" value="line"/>
            <param name="input_type|image" value="input_line.tiff" ftype="tiff"/>
            <param name="model_source|source" value="history"/>
            <!-- The test model is too large (16.9 MB) to include in the repository.
                 Thus pulled from a commit-pinned GitHub URL. Zenodo cannot be used here 
                 because the model is only available inside a ZIP archive. -->
            <param name="model_source|model" value="greek-english_porson_sophoclesplaysa05campgoog.mlmodel" location="https://raw.githubusercontent.com/AjaxMultiCommentary/OCR-kraken-models/e187951d0ebc669929c866f8a43bc303e849ff45/kraken-models/greek-english_porson_sophoclesplaysa05campgoog/greek-english_porson_sophoclesplaysa05campgoog.mlmodel" ftype="binary"/>
            <param name="output_format_flag" value="-x"/>
            <output name="output" ftype="xml">
                <assert_contents>
                    <has_text text="PcGts"/>
                    <has_text text="TextEquiv"/>
                    <has_text text="Pind."/>
                </assert_contents>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="input_type|source" value="line"/>
            <param name="input_type|image" value="lines_2pages.pdf" ftype="pdf"/>
            <param name="model_source|source" value="history"/>
            <param name="model_source|model" value="greek-english_porson_sophoclesplaysa05campgoog.mlmodel" location="https://raw.githubusercontent.com/AjaxMultiCommentary/OCR-kraken-models/e187951d0ebc669929c866f8a43bc303e849ff45/kraken-models/greek-english_porson_sophoclesplaysa05campgoog/greek-english_porson_sophoclesplaysa05campgoog.mlmodel" ftype="binary"/>
            <param name="output_format_flag" value="-y"/>
            <output_collection name="pdf_output" type="list">
                <element name="input.pdf_000000" ftype="xml">
                    <assert_contents>
                        <has_text text="FineReader"/>
                        <has_text text="&gt;P&lt;/charParams&gt;"/>
                        <has_text text="&gt;i&lt;/charParams&gt;"/>
                        <has_text text="&gt;n&lt;/charParams&gt;"/>
                        <has_text text="&gt;d&lt;/charParams&gt;"/>
                        <has_text text="&gt;.&lt;/charParams&gt;"/>
                    </assert_contents>
                </element>
                <element name="input.pdf_000001" ftype="xml">
                    <assert_contents>
                        <has_text text="FineReader"/>
                        <has_text text="&gt;d&lt;/charParams&gt;"/>
                        <has_text text="&gt;e&lt;/charParams&gt;"/>
                        <has_text text="&gt;m&lt;/charParams&gt;"/>
                    </assert_contents>
                </element>
            </output_collection>
        </test>
        <test expect_failure="true">
            <param name="input_type|source" value="line"/>
            <param name="input_type|image" value="input_2pages.tiff" ftype="tiff"/>
            <param name="model_source|source" value="history"/>
            <param name="model_source|model" value="greek-english_porson_sophoclesplaysa05campgoog.mlmodel" location="https://raw.githubusercontent.com/AjaxMultiCommentary/OCR-kraken-models/e187951d0ebc669929c866f8a43bc303e849ff45/kraken-models/greek-english_porson_sophoclesplaysa05campgoog/greek-english_porson_sophoclesplaysa05campgoog.mlmodel" ftype="binary"/>
            <param name="output_format_flag" value="-n"/>
            <assert_stderr>
                <has_text text="multi-page TIF(F) input is not supported"/>
                <has_text text="Detected 2 pages"/>
            </assert_stderr>
        </test>
    </tests>
    <help format="markdown">
**What it does**

Kraken is a powerful OCR system for all languages. 
This tool only exposes Kraken's OCR command.

OCR is the process of extracting text from images. 
Single-line images can be processed directly. 
For document images, a segmentation file in ALTO or PAGE XML format is required. 
This additional input file can be produced by the Kraken segmentation tool, 
which is also available in the Kraken OCR suite.

The OCR output can be returned in various formats, 
including ALTO XML, PageXML, hOCR, abbyyXML, and plain text.

**License**

Kraken is licensed under the Apache-2.0 license.
    </help>
    <expand macro="citations"/>
</tool>
