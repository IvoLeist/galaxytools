<?xml version="1.0" encoding="UTF-8"?>
<tool id="mirtrace_qc" name="miRTrace QC" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>quality control of small RNA sequencing data</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="xrefs"/>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <expand macro="version_command"/>
    <command detect_errors="aggressive"><![CDATA[
@SYMLINK_INPUTS@

mirtrace qc
    --species '$species'
@COMMON_PARAMS@

## Move output files
&& cp output/mirtrace-report.html '$report_html'
&& cp output/mirtrace-results.json '$results_json'

## Collect FASTA outputs into collections if requested
#if $write_fasta
    && mkdir -p fasta_qc_passed fasta_unknown 
    #if $uncollapse_fasta
        && mv output/qc_passed_reads.all.uncollapsed/*.fasta fasta_qc_passed/
        && mv output/qc_passed_reads.rnatype_unknown.uncollapsed/*.fasta fasta_unknown/
    #else
        && mv output/qc_passed_reads.all.collapsed/*.fasta fasta_qc_passed/
        && mv output/qc_passed_reads.rnatype_unknown.collapsed/*.fasta fasta_unknown/
    #end if
    && gzip fasta_qc_passed/*.fasta
    && gzip fasta_unknown/*.fasta
#end if
    ]]></command>
