<?xml version="1.0" encoding="UTF-8"?>
<macros>
    <token name="@TOOL_VERSION@">1.0.1</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.0</token>

    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">mirtrace</requirement>
            <requirement type="package" version="1.14">gzip</requirement>
        </requirements>
    </xml>

    <xml name="version_command">
        <version_command>mirtrace --version 2>&amp;1 | head -1</version_command>
    </xml>

    <xml name="xrefs">
        <xrefs>
            <xref type="bio.tools">miRTrace</xref>
        </xrefs>
    </xml>
    <xml name="creators">
        <creator>
            <person givenName="Pavankumar" 
                        familyName="Videm"  
                        url="https://github.com/pavanvidem"
                        identifier="https://orcid.org/0000-0002-5192-126X"/>
            <organization name="de.NBI"
                        identifier="https://ror.org/01vmpm840"
                        url="https://www.denbi.de/" />
            <organization name="ELIXIR-DE"
                        identifier="https://ror.org/056mykw55"
                        url="https://www.denbi.de/elixir-de" />
        </creator>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.1186/s13059-018-1588-9</citation>
        </citations>
    </xml>

    <token name="@SYMLINK_INPUTS@"><![CDATA[
#set $input_files = []
#for $s in $sample
    #set $sample_name = str($s.element_identifier)
    ln -s '$s' '$sample_name' &&
    #silent $input_files.append($sample_name)
#end for
    ]]></token>

    <token name="@COMMON_PARAMS@"><![CDATA[
    --output-dir output
    #if $adapter
        --adapter '$adapter'
    #end if
    --protocol '$protocol'
    $write_fasta
    $uncollapse_fasta
    #if $title
        --title '$title'
    #end if
    #if $comment
        --comment '$comment'
    #end if
    --num-threads "\${GALAXY_SLOTS:-4}"
    $(' '.join(["'" + $f + "'" for $f in $input_files]))
    ]]></token>

    <token name="@WRITE_FASTA@"><![CDATA[
## Collect FASTA outputs into collections if requested
#if $write_fasta
    && mkdir -p fasta_qc_passed fasta_unknown 
    #if $uncollapse_fasta
        && mv output/qc_passed_reads.all.uncollapsed/*.fasta fasta_qc_passed/
        && mv output/qc_passed_reads.rnatype_unknown.uncollapsed/*.fasta fasta_unknown/
    #else
        && mv output/qc_passed_reads.all.collapsed/*.fasta fasta_qc_passed/
        && mv output/qc_passed_reads.rnatype_unknown.collapsed/*.fasta fasta_unknown/
    #end if
#end if
    ]]></token>

    <xml name="common_input_params">
        <param name="sample" type="data" multiple="true" format="fastq,fastqsanger,fastq.gz,fastqsanger.gz"
                label="FASTQ file(s) to processs"/>
        <param argument="--adapter" type="text" value="" optional="true"
               label="3' adapter sequence"
               help="The 3' adapter sequence used during library preparation (e.g. TGGAATTCTCGGGTGCCAAGG for TruSeq Small RNA).
If not specified, adapter trimming is not performed.">
            <validator type="regex" message="Adapter must contain only ACGTN characters">[ACGTNacgtn]*</validator>
        </param>
        <param argument="--protocol" type="select" label="Library preparation protocol">
            <option value="illumina" selected="true">illumina (miRNA--3'-adapter--index)</option>
            <option value="qiaseq">qiaseq (miRNA--3'-adapter--UMI--3'-adapter--index)</option>
            <option value="cats">cats (NNN--miRNA--poly-A--3'-adapter--index)</option>
            <option value="nextflex">nextflex (NNNN--miRNA--NNNN--3'-adapter--index)</option>
        </param>
    </xml>

    <xml name="common_reporting_params">
        <param argument="--write-fasta" type="boolean" truevalue="--write-fasta" falsevalue="" checked="false"
               label="Write QC-passed reads and unknown reads"
               help="Identical reads are collapsed. Entries are sorted by abundance"/>
        <param argument="--uncollapse-fasta" type="boolean" truevalue="--uncollapse-fasta" falsevalue="" checked="false"
               label="Uncollapse FASTA output"
               help="Write one FASTA entry per original FASTQ entry (only relevant if '--write-fasta' is enabled)."/>
        <param argument="--title" type="text" value="" optional="true"
               label="Report title"
               help="Set the title displayed in the HTML report.">
            <sanitizer>
                <valid initial="string.digits,string.ascii_letters,string.punctuation">
                    <add value=" "/>
                </valid>
            </sanitizer>
        </param>
        <param argument="--comment" type="text" value="" optional="true"
               label="Report comment"
               help="Add a comment to the generated report.">
            <sanitizer>
                <valid initial="string.digits,string.ascii_letters,string.punctuation">
                    <add value=" "/>
                </valid>
            </sanitizer>
        </param>
    </xml>
</macros>
